[
  {
    "name": "theme_info",
    "theme_name": "Skincare Brand Theme",
    "theme_version": "1.0.0",
    "theme_author": "Custom Build",
    "theme_documentation_url": "https://github.com",
    "theme_support_url": "https://github.com"
  },

  {
    "name": "Favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon",
        "info": "PNG or ICO, 32×32px recommended"
      }
    ]
  },

  {
    "name": "Logo",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo image",
        "info": "SVG or PNG with transparent background recommended"
      },
      {
        "type": "range",
        "id": "logo_width",
        "label": "Logo width — desktop",
        "min": 80,
        "max": 200,
        "step": 4,
        "unit": "px",
        "default": 140
      },
      {
        "type": "range",
        "id": "logo_width_mobile",
        "label": "Logo width — mobile",
        "min": 60,
        "max": 150,
        "step": 4,
        "unit": "px",
        "default": 100
      }
    ]
  },

  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_bg",
        "label": "Background color",
        "default": "#FFFFFF"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Text color (primary)",
        "default": "#111111"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent color",
        "default": "#111111"
      },
      {
        "type": "color",
        "id": "color_cream",
        "label": "Cream / surface color",
        "default": "#F5F2ED"
      },
      {
        "type": "color",
        "id": "color_border",
        "label": "Border color",
        "default": "#E8E5E0"
      }
    ]
  },

  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "type_body_font",
        "label": "Body font",
        "default": "inter_n4"
      },
      {
        "type": "range",
        "id": "font_size_base",
        "label": "Base font size",
        "min": 13,
        "max": 18,
        "step": 1,
        "unit": "px",
        "default": 14
      },
      {
        "type": "range",
        "id": "heading_size_scale",
        "label": "Heading size scale",
        "min": 1.0,
        "max": 2.0,
        "step": 0.1,
        "default": 1.5,
        "info": "Multiplier applied to heading font sizes relative to body font size"
      }
    ]
  },

  {
    "name": "Layout",
    "settings": [
      {
        "type": "range",
        "id": "container_max_width",
        "label": "Container max width",
        "min": 1200,
        "max": 1600,
        "step": 20,
        "unit": "px",
        "default": 1400
      },
      {
        "type": "checkbox",
        "id": "sticky_header",
        "label": "Enable sticky header",
        "default": true
      }
    ]
  },

  {
    "name": "Social Media",
    "settings": [
      {
        "type": "url",
        "id": "social_instagram",
        "label": "Instagram URL"
      },
      {
        "type": "url",
        "id": "social_facebook",
        "label": "Facebook URL"
      },
      {
        "type": "url",
        "id": "social_tiktok",
        "label": "TikTok URL"
      },
      {
        "type": "url",
        "id": "social_youtube",
        "label": "YouTube URL"
      },
      {
        "type": "text",
        "id": "social_whatsapp",
        "label": "WhatsApp number",
        "placeholder": "+39...",
        "info": "Include country code, e.g. +39 333 123 4567"
      }
    ]
  },

  {
    "name": "Cart",
    "settings": [
      {
        "type": "text",
        "id": "cart_drawer_title",
        "label": "Cart drawer title",
        "default": "Il tuo carrello"
      },
      {
        "type": "number",
        "id": "free_shipping_threshold",
        "label": "Free shipping threshold (€)",
        "default": 39,
        "info": "Set to 0 to hide the shipping progress bar"
      },
      {
        "type": "number",
        "id": "gift_threshold",
        "label": "Gift-with-purchase threshold (€)",
        "default": 39,
        "info": "Spend this amount to unlock the gift product below"
      },
      {
        "type": "product",
        "id": "gift_product",
        "label": "Gift product",
        "info": "The product unlocked as a gift when the threshold is reached"
      },
      {
        "type": "text",
        "id": "gift_tracker_text",
        "label": "Gift tracker message",
        "default": "Spendi €39 e sblocca una Mini Beauty Case in omaggio"
      },
      {
        "type": "checkbox",
        "id": "show_loyalty_estimate",
        "label": "Show loyalty points estimate",
        "default": true
      },
      {
        "type": "text",
        "id": "loyalty_estimate_text",
        "label": "Loyalty estimate text",
        "default": "Con questo ordine guadagnerai punti fedeltà"
      }
    ]
  },

  {
    "name": "Search",
    "settings": [
      {
        "type": "header",
        "content": "Popular search suggestions"
      },
      {
        "type": "text",
        "id": "search_popular_1",
        "label": "Popular search 1",
        "default": "Detergente viso"
      },
      {
        "type": "text",
        "id": "search_popular_2",
        "label": "Popular search 2",
        "default": "Vitamina C"
      },
      {
        "type": "text",
        "id": "search_popular_3",
        "label": "Popular search 3",
        "default": "Crema viso"
      },
      {
        "type": "text",
        "id": "search_popular_4",
        "label": "Popular search 4",
        "default": "SPF"
      },
      {
        "type": "text",
        "id": "search_popular_5",
        "label": "Popular search 5",
        "default": "Retinolo"
      }
    ]
  },

  {
    "name": "Navigation",
    "settings": [
      {
        "type": "link_list",
        "id": "main_menu",
        "label": "Main menu",
        "default": "main-menu"
      },
      {
        "type": "link_list",
        "id": "footer_menu_1",
        "label": "Footer — Shop column",
        "default": "footer"
      },
      {
        "type": "link_list",
        "id": "footer_menu_2",
        "label": "Footer — Brand column"
      },
      {
        "type": "link_list",
        "id": "footer_menu_3",
        "label": "Footer — Customer care column"
      },
      {
        "type": "link_list",
        "id": "footer_menu_4",
        "label": "Footer — Contacts column"
      }
    ]
  },

  {
    "name": "Product Page",
    "settings": [
      {
        "type": "checkbox",
        "id": "show_trust_badge",
        "label": "Show pharmacist trust badge",
        "default": true
      },
      {
        "type": "text",
        "id": "trust_badge_text",
        "label": "Trust badge text",
        "default": "FORMULATO DA FARMACISTI"
      },
      {
        "type": "checkbox",
        "id": "show_free_shipping_note",
        "label": "Show free shipping note",
        "default": true
      },
      {
        "type": "text",
        "id": "free_shipping_note",
        "label": "Free shipping note",
        "default": "Spedizione gratuita sopra €39"
      },
      {
        "type": "checkbox",
        "id": "show_sample_offer",
        "label": "Show sample gift offer",
        "default": true
      },
      {
        "type": "text",
        "id": "sample_offer_text",
        "label": "Sample offer text",
        "default": "Scegli il tuo campione omaggio con ogni ordine"
      },
      {
        "type": "checkbox",
        "id": "show_klarna",
        "label": "Show Klarna BNPL badge",
        "default": false
      }
    ]
  },

  {
    "name": "Footer",
    "settings": [
      {
        "type": "text",
        "id": "footer_copyright",
        "label": "Copyright text",
        "default": "© 2024 Skincare Brand. Tutti i diritti riservati."
      },
      {
        "type": "richtext",
        "id": "footer_address",
        "label": "Company address / contact info"
      },
      {
        "type": "image_picker",
        "id": "footer_payment_image",
        "label": "Payment methods image",
        "info": "Single image showing all accepted payment icons"
      }
    ]
  },

  {
    "name": "Advanced",
    "settings": [
      {
        "type": "textarea",
        "id": "custom_css",
        "label": "Custom CSS",
        "info": "Injected into <head> site-wide"
      },
      {
        "type": "textarea",
        "id": "custom_js",
        "label": "Custom JavaScript",
        "info": "Injected before </body> with defer. Use carefully."
      },
      {
        "type": "text",
        "id": "google_analytics_id",
        "label": "Google Analytics 4 ID",
        "placeholder": "G-XXXXXXXXXX"
      },
      {
        "type": "text",
        "id": "facebook_pixel_id",
        "label": "Meta Pixel ID"
      }
    ]
  }
]
