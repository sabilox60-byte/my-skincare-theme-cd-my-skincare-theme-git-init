{%- comment -%}
  protocols-slider.liquid
  ────────────────────────
  Horizontal-scroll card carousel — skin protocol collections.
  Swiper config: freeMode, no autoplay, dots on mobile only.
  slidesPerView: 1.2 (mob) → 3.5 (768px) → 4.5 (1024px)
  JS init delegates to Theme.Slider.initProtocolsSlider() in assets/theme.js.
{%- endcomment -%}

<section class="section-protocols-slider"
         data-section-id="{{ section.id }}">

  {%- comment -%} ── Header (constrained to container) ── {%- endcomment -%}
  <div class="container">
    <div class="protocols-slider__header">

      {%- if section.settings.eyebrow != blank -%}
        <p class="protocols-slider__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}

      <div class="protocols-slider__header-row">
        <h2 class="protocols-slider__heading">
          {{ section.settings.heading | escape }}
        </h2>
        {%- if section.settings.view_all_link != blank -%}
          <a href="{{ section.settings.view_all_link }}"
             class="protocols-slider__view-all">
            Visualizza tutto
            {%- render 'icon-sprite', icon: 'icon-arrow-right' -%}
          </a>
        {%- endif -%}
      </div>

      {%- if section.settings.subheading != blank -%}
        <p class="protocols-slider__subheading">
          {{ section.settings.subheading | escape }}
        </p>
      {%- endif -%}

    </div>
  </div>

  {%- comment -%}
    Track wrapper intentionally bleeds past .container so Swiper cards
    can extend to the right edge of the viewport (overflow reveal effect).
  {%- endcomment -%}
  <div class="protocols-slider__track-wrapper">
    <div class="swiper protocols-swiper"
         data-protocols-swiper>

      <div class="swiper-wrapper">
        {%- for block in section.blocks -%}
          <div class="swiper-slide protocol-card"
               {{ block.shopify_attributes }}>

            <a href="{{ block.settings.link | default: '#' }}"
               class="protocol-card__link">

              <div class="protocol-card__media">
                {%- if block.settings.image != blank -%}
                  <img src="{{ block.settings.image | image_url: width: 600 }}"
                       srcset="{{ block.settings.image | image_url: width: 300 }} 300w,
                               {{ block.settings.image | image_url: width: 600 }} 600w"
                       sizes="(min-width: 1024px) 22vw, (min-width: 768px) 30vw, 80vw"
                       alt="{{ block.settings.title | escape }}"
                       loading="lazy"
                       width="300"
                       height="400">
                {%- else -%}
                  <div class="protocol-card__media-placeholder" aria-hidden="true"></div>
                {%- endif -%}
              </div>

              <div class="protocol-card__body">
                {%- if block.settings.title != blank -%}
                  <h3 class="protocol-card__title">{{ block.settings.title | escape }}</h3>
                {%- endif -%}
                <span class="protocol-card__cta">
                  Quello giusto per me
                  {%- render 'icon-sprite', icon: 'icon-arrow-right' -%}
                </span>
              </div>

            </a>
          </div>{%- comment -%} /.swiper-slide {%- endcomment -%}
        {%- endfor -%}
      </div>{%- comment -%} /.swiper-wrapper {%- endcomment -%}

      {%- comment -%} Pagination — shown mobile only via CSS {%- endcomment -%}
      <div class="swiper-pagination protocols-pagination"
           aria-label="Navigazione protocolli"></div>

    </div>{%- comment -%} /.swiper.protocols-swiper {%- endcomment -%}
  </div>{%- comment -%} /.protocols-slider__track-wrapper {%- endcomment -%}

</section>

<style>
  /* ─── Section shell ─── */
  .section-protocols-slider {
    padding-block: var(--space-2xl);
    overflow: hidden;
  }

  /* ─── Header area ─── */
  .protocols-slider__eyebrow {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-medium);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: var(--space-sm);
  }

  .protocols-slider__header-row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-md);
    flex-wrap: wrap;
    margin-bottom: var(--space-sm);
  }

  .protocols-slider__heading {
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-medium);
    color: var(--color-text);
    line-height: var(--line-height-heading);
  }

  .protocols-slider__view-all {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    white-space: nowrap;
    text-decoration: underline;
    flex-shrink: 0;
    transition: color var(--transition-fast);
  }

  .protocols-slider__view-all:hover {
    color: var(--color-text);
  }

  .protocols-slider__view-all svg {
    width: 14px;
    height: 14px;
  }

  .protocols-slider__subheading {
    font-size: var(--font-size-base);
    color: var(--color-text-muted);
    line-height: var(--line-height-base);
    margin-bottom: var(--space-lg);
  }

  /* ─── Track wrapper: left-aligned with container padding, bleeds right ─── */
  .protocols-slider__track-wrapper {
    padding-left: var(--container-padding);
    overflow: visible;
    margin-top: var(--space-xl);
  }

  /* ─── Swiper overrides ─── */
  .protocols-swiper {
    overflow: visible !important;
  }

  /* ─── Individual protocol card ─── */
  .protocol-card {
    border-radius: var(--radius-lg);
    overflow: hidden;
    background-color: var(--color-bg);
    box-shadow: 0 2px 8px var(--overlay-light);
    transition: box-shadow var(--transition-base);
  }

  .protocol-card:hover {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.12);
  }

  .protocol-card__link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: var(--color-text);
  }

  .protocol-card__link:hover {
    text-decoration: none;
  }

  /* Image area — portrait 3:4 */
  .protocol-card__media {
    aspect-ratio: 3 / 4;
    overflow: hidden;
    flex-shrink: 0;
    background-color: var(--color-cream);
  }

  .protocol-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    transition: transform var(--transition-slow);
  }

  .protocol-card:hover .protocol-card__media img {
    transform: scale(1.03);
  }

  .protocol-card__media-placeholder {
    width: 100%;
    height: 100%;
    background-color: var(--color-cream);
  }

  /* Card body */
  .protocol-card__body {
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    background-color: var(--color-bg);
    border-top: var(--border);
    flex: 1;
  }

  .protocol-card__title {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-medium);
    color: var(--color-text);
    line-height: 1.3;
  }

  .protocol-card__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    margin-top: var(--space-xs);
    transition: color var(--transition-fast), gap var(--transition-fast);
  }

  .protocol-card__cta svg {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    transition: transform var(--transition-fast);
  }

  .protocol-card:hover .protocol-card__cta {
    color: var(--color-text);
  }

  .protocol-card:hover .protocol-card__cta svg {
    transform: translateX(3px);
  }

  /* ─── Pagination: mobile only ─── */
  .protocols-pagination {
    display: flex;
    justify-content: center;
    margin-top: var(--space-lg);
  }

  .protocols-pagination .swiper-pagination-bullet {
    background-color: var(--color-border-dark);
    opacity: 1;
  }

  .protocols-pagination .swiper-pagination-bullet-active {
    background-color: var(--color-text);
  }

  @media (min-width: 768px) {
    .protocols-pagination {
      display: none;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    if (typeof Theme !== 'undefined' && Theme.Slider) {
      Theme.Slider.initProtocolsSlider();
    }
  });
</script>

{% schema %}
