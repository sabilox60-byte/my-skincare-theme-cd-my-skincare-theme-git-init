{%- comment -%} ── Scoped styles ── {%- endcomment -%}
<style>
  /* ─── Header shell ─── */
  .header {
    background-color: var(--color-bg);
    border-bottom: var(--border);
    z-index: calc(var(--z-sticky) + 10);
    position: relative;
    transition: box-shadow 0.2s ease, height 0.2s ease;
  }

  .header--sticky {
    position: sticky;
    top: 0;
  }

  .header--scrolled {
    box-shadow: 0 2px 16px var(--overlay-light);
  }

  .header__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    height: 64px;
    gap: var(--space-md);
    transition: height 0.2s ease;
  }

  .header--scrolled .header__inner {
    height: 56px;
  }

  /* ─── Desktop nav (left zone) ─── */
  .header__nav {
    display: none;
  }

  .header__nav-list {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .header__nav-item {
    position: relative;
  }

  .header__nav-trigger {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-family: var(--font-body);
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-medium);
    color: var(--color-text);
    padding-block: var(--space-md);
    background: none;
    border: none;
    cursor: pointer;
    white-space: nowrap;
    transition: color var(--transition-fast);
  }

  .header__nav-trigger:hover {
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .header__nav-trigger svg {
    width: 12px;
    height: 12px;
    flex-shrink: 0;
    transition: transform var(--transition-fast);
  }

  .header__nav-item.is-open > .header__nav-trigger svg {
    transform: rotate(180deg);
  }

  /* ─── Logo (centre zone) ─── */
  .header__logo {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .header__logo img {
    width: auto;
    max-width: {{ settings.logo_width | default: 140 }}px;
    height: auto;
    display: block;
  }

  .header__logo-text {
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-medium);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text);
    white-space: nowrap;
  }

  /* ─── Utils (right zone) ─── */
  .header__utils {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: var(--space-xs);
  }

  .header__icon-btn {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-sm);
    color: var(--color-text);
    transition: background-color var(--transition-fast);
    flex-shrink: 0;
    background: none;
    border: none;
    cursor: pointer;
    text-decoration: none;
  }

  .header__icon-btn:hover {
    background-color: var(--color-cream);
    text-decoration: none;
  }

  .header__icon-btn svg {
    width: 20px;
    height: 20px;
  }

  /* Cart count badge */
  .header__cart-count {
    position: absolute;
    top: 4px;
    right: 4px;
    min-width: 16px;
    height: 16px;
    padding: 0 3px;
    border-radius: var(--radius-pill);
    background-color: var(--color-text);
    color: var(--color-bg);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-medium);
    line-height: 16px;
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .header__cart-count[data-count="0"] {
    display: none;
  }

  /* Hamburger — visible on mobile only */
  .header__hamburger {
    display: flex;
  }

  /* ─── Mega menu ─── */
  .mega-menu {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background-color: var(--color-bg);
    border-top: var(--border);
    border-bottom: var(--border);
    box-shadow: 0 8px 32px var(--overlay-light);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    z-index: var(--z-dropdown);
    transition: opacity 0.2s ease, visibility 0.2s ease;
  }

  .mega-menu.is-open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .mega-menu__inner {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
    padding-block: 32px;
  }

  .mega-menu__col-title {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-medium);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
  }

  .mega-menu__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .mega-menu__link {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--font-size-base);
    color: var(--color-text);
    transition: color var(--transition-fast);
    line-height: 1.4;
  }

  .mega-menu__link:hover {
    color: var(--color-text-muted);
    text-decoration: none;
  }

  /* Step routine numbers */
  .step-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background-color: var(--color-text);
    color: var(--color-bg);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-medium);
    flex-shrink: 0;
    line-height: 1;
  }

  /* Skin concerns — 2 sub-columns */
  .concerns-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4px var(--space-md);
  }

  /* Mega menu inline badges */
  .mega-badge {
    display: inline-flex;
    align-items: center;
    padding: 2px 6px;
    border-radius: var(--radius-pill);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-medium);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    line-height: 1.4;
    white-space: nowrap;
  }

  .mega-badge--limited { background-color: var(--color-error);   color: var(--color-bg); }
  .mega-badge--science { background-color: var(--color-text);    color: var(--color-bg); }
  .mega-badge--new     { background-color: var(--color-success); color: var(--color-bg); }
  .mega-badge--smart   { background-color: var(--color-cream);   color: var(--color-text); border: var(--border); }

  /* Mega menu banner column */
  .mega-menu__col--banner {
    display: flex;
    align-items: stretch;
  }

  .mega-menu__banner-link {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border-radius: var(--radius-md);
    width: 100%;
    position: relative;
    text-decoration: none;
  }

  .mega-menu__banner-link img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
    flex: 1;
  }

  .mega-menu__banner-link:hover img {
    transform: scale(1.04);
  }

  .mega-menu__banner-cta {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    padding: var(--space-sm) var(--space-md);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    color: var(--color-text);
    background-color: var(--color-bg);
    border-top: var(--border);
    flex-shrink: 0;
  }

  .mega-menu__banner-cta svg {
    width: 14px;
    height: 14px;
  }

  /* ─── Mobile nav drawer ─── */
  .mobile-nav {
    position: fixed;
    top: 0;
    left: 0;
    width: min(360px, 100vw);
    height: 100dvh;
    background-color: var(--color-bg);
    z-index: var(--z-drawer);
    display: flex;
    flex-direction: column;
    transform: translateX(-100%);
    transition: transform 0.3s ease;
    overflow-y: auto;
    overscroll-behavior: contain;
  }

  .mobile-nav.is-open {
    transform: translateX(0);
  }

  .mobile-nav__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-md) var(--container-padding);
    border-bottom: var(--border);
    min-height: 64px;
    flex-shrink: 0;
  }

  .mobile-nav__logo {
    display: flex;
    align-items: center;
    color: var(--color-text);
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-medium);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .mobile-nav__logo img {
    max-width: {{ settings.logo_width_mobile | default: 100 }}px;
    height: auto;
  }

  .mobile-nav__close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-sm);
    color: var(--color-text);
    transition: background-color var(--transition-fast);
  }

  .mobile-nav__close:hover {
    background-color: var(--color-cream);
  }

  .mobile-nav__close svg {
    width: 20px;
    height: 20px;
  }

  .mobile-nav__list {
    flex: 1;
    padding: var(--space-sm) 0;
  }

  .mobile-nav__item {
    border-bottom: var(--border);
  }

  .mobile-nav__trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: var(--space-md) var(--container-padding);
    font-family: var(--font-body);
    font-size: var(--font-size-md);
    font-weight: var(--font-weight-medium);
    color: var(--color-text);
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    text-decoration: none;
    transition: background-color var(--transition-fast);
  }

  .mobile-nav__trigger:hover {
    background-color: var(--color-cream);
    text-decoration: none;
  }

  .mobile-nav__trigger svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    color: var(--color-text-muted);
    transition: transform var(--transition-fast);
  }

  .mobile-nav__item--has-sub .mobile-nav__trigger[aria-expanded="true"] svg {
    transform: rotate(90deg);
  }

  /* Sub-panel list */
  .mobile-nav__sub {
    padding: 0 var(--container-padding) var(--space-md);
    background-color: var(--color-cream);
  }

  .mobile-nav__sub[hidden] {
    display: none;
  }

  .mobile-nav__sub li {
    border-bottom: var(--border);
  }

  .mobile-nav__sub li:last-child {
    border-bottom: none;
  }

  .mobile-nav__sub a {
    display: block;
    padding: var(--space-sm) var(--space-md);
    font-size: var(--font-size-base);
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
  }

  .mobile-nav__sub a:hover {
    color: var(--color-text);
    text-decoration: none;
  }

  /* Footer links row */
  .mobile-nav__footer {
    display: flex;
    gap: var(--space-md);
    padding: var(--space-lg) var(--container-padding);
    border-top: var(--border);
    flex-shrink: 0;
    flex-wrap: wrap;
  }

  .mobile-nav__footer a {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
  }

  .mobile-nav__footer a:hover {
    color: var(--color-text);
    text-decoration: none;
  }

  .mobile-nav__footer svg {
    width: 16px;
    height: 16px;
  }

  /* Mobile nav overlay */
  .mobile-nav__overlay {
    position: fixed;
    inset: 0;
    background-color: var(--overlay-mid);
    z-index: calc(var(--z-drawer) - 1);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .mobile-nav__overlay.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  /* ─── Responsive breakpoints ─── */

  /* Desktop: show nav, hide hamburger */
  @media (min-width: 1024px) {
    .header__nav {
      display: flex;
    }

    .header__hamburger {
      display: none;
    }
  }

  /* Tablet: compact utils gap */
  @media (min-width: 768px) and (max-width: 1023px) {
    .header__inner {
      grid-template-columns: auto 1fr auto;
    }

    .header__nav {
      display: none;
    }
  }
</style>

