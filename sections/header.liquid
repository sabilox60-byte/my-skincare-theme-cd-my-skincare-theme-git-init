{%- comment -%}
  header.liquid
  ─────────────
  3-zone sticky header: [Desktop Nav] [Logo] [Utils]
  Mega menu for Skincare (hardcoded per live store structure).
  Mobile nav drawer slides in from the left.
  All interactive JS is handled by Theme.Menu in assets/theme.js.
  No {% javascript %} block — zero duplication.
{%- endcomment -%}

<header class="header{% if section.settings.sticky_header %} header--sticky{% endif %}"
        id="site-header"
        data-header
        data-section-id="{{ section.id }}">

  <div class="header__inner container">

    {%- comment -%}══════════════ LEFT: Desktop navigation ══════════════{%- endcomment -%}
    <nav class="header__nav" aria-label="Navigazione principale">
      <ul class="header__nav-list" role="list">

        {%- comment -%} Schema-driven nav items {%- endcomment -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'nav_item' -%}
            <li class="header__nav-item{% if block.settings.has_mega_menu %} has-mega-menu{% endif %}"
                data-mega-trigger
                {{ block.shopify_attributes }}>

              {%- if block.settings.has_mega_menu -%}
                <button class="header__nav-trigger"
                        data-mega-link
                        aria-expanded="false"
                        aria-haspopup="true"
                        aria-controls="mega-{{ block.id | replace: '-', '' }}">
                  {{ block.settings.label | escape }}
                  {%- render 'icon-sprite', icon: 'icon-chevron-down' -%}
                </button>
              {%- elsif block.settings.link != blank -%}
                <a class="header__nav-trigger header__nav-link"
                   href="{{ block.settings.link }}">
                  {{ block.settings.label | escape }}
                </a>
              {%- else -%}
                <span class="header__nav-trigger header__nav-link">
                  {{ block.settings.label | escape }}
                </span>
              {%- endif -%}

            </li>
          {%- endif -%}
        {%- endfor -%}

        {%- comment -%} Fallback static items if no blocks are configured {%- endcomment -%}
        {%- if section.blocks.size == 0 -%}
          <li class="header__nav-item has-mega-menu" data-mega-trigger>
            <button class="header__nav-trigger"
                    data-mega-link
                    aria-expanded="false"
                    aria-haspopup="true"
                    aria-controls="mega-skincare">
              Skincare
              {%- render 'icon-sprite', icon: 'icon-chevron-down' -%}
            </button>
          </li>
          <li class="header__nav-item">
            <a class="header__nav-trigger header__nav-link"
               href="/collections/protocolli">Protocolli</a>
          </li>
          <li class="header__nav-item">
            <a class="header__nav-trigger header__nav-link"
               href="/pages/make-up">Make-up</a>
          </li>
        {%- endif -%}

      </ul>
    </nav>

    {%- comment -%}══════════════ CENTER: Logo ══════════════{%- endcomment -%}
    <a href="{{ routes.root_url }}"
       class="header__logo"
       aria-label="{{ shop.name | escape }}">
      {%- if settings.logo != blank -%}
        <img src="{{ settings.logo | image_url: width: 280 }}"
             srcset="{{ settings.logo | image_url: width: 140 }} 140w,
                     {{ settings.logo | image_url: width: 280 }} 280w"
             sizes="{{ settings.logo_width | default: 140 }}px"
             alt="{{ shop.name | escape }}"
             width="{{ settings.logo_width | default: 140 }}"
             height="auto"
             loading="eager"
             fetchpriority="high">
      {%- else -%}
        <span class="header__logo-text">{{ shop.name | escape }}</span>
      {%- endif -%}
    </a>

    {%- comment -%}══════════════ RIGHT: Utilities ══════════════{%- endcomment -%}
    <div class="header__utils">

      {%- comment -%} Search {%- endcomment -%}
      <button class="header__icon-btn"
              type="button"
              data-open-search
              aria-label="Apri ricerca"
              aria-controls="search-drawer"
              aria-expanded="false">
        {%- render 'icon-sprite', icon: 'icon-search' -%}
      </button>

      {%- comment -%} Account {%- endcomment -%}
      <a href="{{ routes.account_url }}"
         class="header__icon-btn"
         aria-label="Account">
        {%- render 'icon-sprite', icon: 'icon-account' -%}
      </a>

      {%- comment -%} Cart {%- endcomment -%}
      <button class="header__icon-btn header__cart-btn"
              type="button"
              data-open-cart
              aria-label="Carrello"
              aria-controls="cart-drawer"
              aria-expanded="false">
        {%- render 'icon-sprite', icon: 'icon-cart' -%}
        <span class="cart-count header__cart-count"
              data-cart-count
              aria-live="polite"
              data-count="{{ cart.item_count }}">
          {{ cart.item_count }}
        </span>
      </button>

      {%- comment -%} Mobile hamburger — hidden on desktop via CSS {%- endcomment -%}
      <button class="header__icon-btn header__hamburger"
              type="button"
              data-hamburger
              aria-label="Apri menu"
              aria-expanded="false"
              aria-controls="mobile-nav">
        {%- render 'icon-sprite', icon: 'icon-menu' -%}
      </button>

    </div>{%- comment -%} /.header__utils {%- endcomment -%}

  </div>{%- comment -%} /.header__inner {%- endcomment -%}

