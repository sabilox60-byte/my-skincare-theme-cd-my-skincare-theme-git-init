{%- comment -%}
  video-feature.liquid
  ─────────────────────
  Full-width brand storytelling video section.
  Supports Shopify-hosted video with autoplay/loop, fallback poster image,
  optional dark overlay, and optional text/CTA overlay.
  On mobile: video hidden, poster image shown instead.
{%- endcomment -%}

<section class="section-video-feature"
         data-section-id="{{ section.id }}">

  <div class="video-feature__media">

    {%- if section.settings.video != blank -%}
      {{- section.settings.video | video_tag:
            autoplay: section.settings.autoplay,
            muted: true,
            loop: section.settings.loop,
            playsinline: true,
            class: 'video-feature__video',
            poster: section.settings.poster_image | image_url: width: 1920
      -}}
    {%- elsif section.settings.poster_image != blank -%}
      <img src="{{ section.settings.poster_image | image_url: width: 1920 }}"
           srcset="{{ section.settings.poster_image | image_url: width: 800 }} 800w,
                   {{ section.settings.poster_image | image_url: width: 1200 }} 1200w,
                   {{ section.settings.poster_image | image_url: width: 1920 }} 1920w"
           sizes="100vw"
           alt="{{ section.settings.poster_image.alt | escape }}"
           loading="lazy"
           width="1920"
           height="1080">
    {%- endif -%}

    {%- if section.settings.overlay_opacity > 0 -%}
      <div class="video-feature__overlay"
           style="background: rgba(0,0,0,{{ section.settings.overlay_opacity | divided_by: 100.0 }});"
           aria-hidden="true">
      </div>
    {%- endif -%}

  </div>

  {%- if section.settings.heading != blank
      or section.settings.subheading != blank
      or section.settings.cta_label != blank -%}

    <div class="video-feature__content video-feature__content--{{ section.settings.content_position | default: 'bottom-left' }}">

      {%- if section.settings.eyebrow != blank -%}
        <p class="video-feature__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="video-feature__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <p class="video-feature__subheading">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}

      {%- if section.settings.cta_label != blank and section.settings.cta_link != blank -%}
        <a href="{{ section.settings.cta_link }}"
           class="btn {% if section.settings.cta_style == 'outline-white' %}btn-outline-white{% else %}btn-primary{% endif %}">
          {{ section.settings.cta_label | escape }}
        </a>
      {%- endif -%}

    </div>

  {%- endif -%}

</section>

<style>
  /* ─── Section wrapper ─── */
  .section-video-feature {
    position: relative;
    width: 100%;
    overflow: hidden;
    height: clamp(300px, 50vw, 600px);
  }

  @media (min-width: 1024px) {
    .section-video-feature {
      height: 70vh;
    }
  }

  /* ─── Media layer (fills section) ─── */
  .video-feature__media {
    position: absolute;
    inset: 0;
  }

  .video-feature__video,
  .video-feature__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  /* ─── Dark overlay ─── */
  .video-feature__overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  /* ─── Text / CTA content ─── */
  .video-feature__content {
    position: absolute;
    z-index: 2;
    color: var(--color-bg);
    padding: var(--space-xl);
    max-width: 600px;
  }

  .video-feature__content--center {
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    width: 100%;
  }

  .video-feature__content--bottom-left {
    bottom: var(--space-xl);
    left: var(--space-xl);
  }

  /* ─── Text elements ─── */
  .video-feature__eyebrow {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--space-sm);
    opacity: 0.85;
    color: var(--color-bg);
  }

  .video-feature__heading {
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-medium);
    color: var(--color-bg);
    margin-bottom: var(--space-md);
    line-height: 1.2;
  }

  .video-feature__subheading {
    font-size: var(--font-size-md);
    color: var(--color-bg);
    margin-bottom: var(--space-lg);
    opacity: 0.9;
    max-width: 480px;
    line-height: var(--line-height-base);
  }

  /* ─── Mobile: hide video, show poster only ─── */
  @media (max-width: 767px) {
    .video-feature__video {
      display: none;
    }

    .video-feature__content {
      padding: var(--space-lg);
      max-width: 100%;
    }

    .video-feature__content--center {
      width: 90%;
    }
  }
</style>

{% schema %}
{
  "name": "Video Feature",
  "settings": [
    {
      "type": "video",
      "id": "video",
      "label": "Video",
      "info": "Shopify-hosted video. Autoplay, muted, loop."
    },
    {
      "type": "image_picker",
      "id": "poster_image",
      "label": "Poster / fallback image",
      "info": "Shown on mobile or when no video is set. Recommended: 1920×1080px."
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay video",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop video",
      "default": true
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay darkness (%)",
      "min": 0,
      "max": 70,
      "step": 5,
      "default": 20,
      "info": "Darkens the video so text is more legible. Set to 0 to disable."
    },
    {
      "type": "header",
      "content": "Text overlay"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Text position",
      "options": [
        { "value": "center",      "label": "Center" },
        { "value": "bottom-left", "label": "Bottom left" }
      ],
      "default": "bottom-left"
    },
    {
      "type": "header",
      "content": "Call to action"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "cta_style",
      "label": "Button style",
      "options": [
        { "value": "outline-white", "label": "White outline" },
        { "value": "primary",       "label": "Black (primary)" }
      ],
      "default": "outline-white"
    }
  ],
  "presets": [
    {
      "name": "Video Feature"
    }
  ]
}
{% endschema %}
