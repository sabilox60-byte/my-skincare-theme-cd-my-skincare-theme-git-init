{%- comment -%}
  icon-sprite.liquid
  ──────────────────
  Centralised SVG icon library.
  All icons: 24×24 viewBox, aria-hidden="true", currentColor stroke/fill.
  Usage: {% render 'icon-sprite', icon: 'icon-search' %}
{%- endcomment -%}

{%- case icon -%}

  {%- comment -%}╔══════════════════════════════╗
                  ║   NAVIGATION & UI ICONS       ║
                  ╚══════════════════════════════╝{%- endcomment -%}

  {%- when 'icon-menu' -%}
    {%- comment -%} Hamburger — 3 horizontal lines {%- endcomment -%}
    <svg aria-hidden="true" focusable="false"
         xmlns="http://www.w3.org/2000/svg"
         width="24" height="24" viewBox="0 0 24 24"
         fill="none" stroke="currentColor"
         stroke-width="1.5" stroke-linecap="round">
      <line x1="3" y1="6"  x2="21" y2="6"/>
      <line x1="3" y1="12" x2="21" y2="12"/>
      <line x1="3" y1="18" x2="21" y2="18"/>
    </svg>

  {%- when 'icon-close' -%}
    {%- comment -%} X — two diagonal crossing lines {%- endcomment -%}
    <svg aria-hidden="true" focusable="false"
         xmlns="http://www.w3.org/2000/svg"
         width="24" height="24" viewBox="0 0 24 24"
         fill="none" stroke="currentColor"
         stroke-width="1.5" stroke-linecap="round">
      <line x1="18" y1="6"  x2="6"  y2="18"/>
      <line x1="6"  y1="6"  x2="18" y2="18"/>
    </svg>

